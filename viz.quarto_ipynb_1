    "# 1. Definimos la selección vinculada a la leyenda\n",
    "selection_line = alt.selection_point(fields=['Source'], bind='legend')\n",
    "\n",
    "continent_source_year = (\n",
    "    df_long.groupby([\"Continent\", \"Year\", \"Source\"], as_index=False)[\"Generation_TWh\"]\n",
    "    .sum()\n",
    ")\n",
    "\n",
    "chart2 = alt.Chart(continent_source_year).mark_line().encode(\n",
    "    x=alt.X(\"Year:O\", title=\"Año\"),\n",
    "    y=alt.Y(\"Generation_TWh:Q\", title=\"Generación eléctrica (TWh)\"),\n",
    "    color=alt.Color(\"Source:N\", title=\"Fuente\"),\n",
    "    # 2. Aplicamos la opacidad condicional\n",
    "    opacity=alt.condition(selection_line, alt.value(1), alt.value(0.1)),\n",
    "    tooltip=[\"Continent:N\", \"Year:O\", \"Source:N\", \"Generation_TWh:Q\"]\n",
    ").properties(\n",
    "    width=220,\n",
    "    height=180\n",
    ").add_params(\n",
    "    # 3. Registramos la selección\n",
    "    selection_line\n",
    ").facet(\n",
    "    column=alt.Column(\"Continent:N\", title=None, header=alt.Header(labelOrient='bottom'))\n",
    ")\n",
    "\n",
    "chart2"
   ]
